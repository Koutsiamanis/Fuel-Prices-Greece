RewriteEngine On

# Route everything that isn't a real file or directory through index.php.
# The matched path is passed as the `_route` query param.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php?_route=$1 [QSA,L]

# Deny direct access to PHP files other than index.php
<FilesMatch "\.(php)$">
    Require all granted
</FilesMatch>
<Files "config.php">
    Require all denied
</Files>
<Files "auth.php">
    Require all denied
</Files>
<Files "helpers.php">
    Require all denied
</Files>
<FilesMatch "^\.env">
    Require all denied
</FilesMatch>
